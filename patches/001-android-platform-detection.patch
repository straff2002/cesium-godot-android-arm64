+def is_android_target(argsDict=None):
+    """Check if we're building for Android (cross-compilation)."""
+    if argsDict and argsDict.get("platform", "") == "android":
+        return True
+    # Also check SCons env if passed
+    if argsDict and hasattr(argsDict, '__getitem__') and argsDict.get("platform", "") == "android":
+        return True
+    return False

 def determine_triplet(argsDict=None):
