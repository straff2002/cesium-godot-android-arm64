+# ── Android ARM64 library configuration ──────────────────────────────────
+if env["platform"] == "android":
+    cesium_build = os.environ.get(
+        "CESIUM_NATIVE_BUILD_DIR",
+        os.path.join(cesium_dir, "build-android-arm64")
+    )
+
+    # cesium-native libraries (static .a files from Android ARM64 build)
+    cesium_lib_names = [
+        "Cesium3DTilesContent",
+        "Cesium3DTilesReader",
+        "Cesium3DTilesSelection",
+        "CesiumAsync",
+        "CesiumGeometry",
+        "CesiumGeospatial",
+        "CesiumGltf",
+        "CesiumGltfContent",
+        "CesiumGltfReader",
+        "CesiumIonClient",
+        "CesiumJsonReader",
+        "CesiumQuantizedMeshTerrain",
+        "CesiumRasterOverlays",
+        "CesiumUtility",
+    ]
+
+    # Add library search paths — each cesium-native library builds in its own directory
+    for lib in cesium_lib_names:
+        lib_path = os.path.join(cesium_build, lib)
+        if os.path.isdir(lib_path):
+            env.Append(LIBPATH=[lib_path])
+        # Some builds put libs in Release/ subdirectory
+        release_path = os.path.join(lib_path, "Release")
+        if os.path.isdir(release_path):
+            env.Append(LIBPATH=[release_path])
+
+    # vcpkg installed dependencies (built by cesium-native's cmake)
+    vcpkg_lib = os.path.join(cesium_build, "vcpkg_installed", "arm64-android", "lib")
+    if os.path.isdir(vcpkg_lib):
+        env.Append(LIBPATH=[vcpkg_lib])
+
+    # Link cesium-native libraries
+    env.Append(LIBS=cesium_lib_names)
+
+    # Android system libraries
+    env.Append(LIBS=["log", "android", "z"])
+
+    # Use Godot HTTP client instead of curl (avoids OpenSSL linking issues)
+    env.Append(CPPDEFINES=["CESIUM_USE_GODOT_HTTP_CLIENT"])
+
+
